{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/verify_file.py",
            "timeout": 120,
            "statusMessage": "Verifying edited file..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/verify_build.py",
            "timeout": 600,
            "statusMessage": "Running build/test gate..."
          }
        ]
      }
    ]
  }
}
