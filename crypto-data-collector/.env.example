# Development-only example. In production, set secrets in the deployment
# provider's encrypted environment; never create a plaintext production file.
HAVEN_ENV=development
HAVEN_SOLO=1
DATABASE_URL=sqlite:///crypto_data.db
HAVEN_CORS_ORIGINS=http://localhost:5173

# Sole external market-data provider.
CMC_API_KEY=
CMC_ASSET_LIMIT=2000
CMC_METADATA_ASSET_LIMIT=300
CMC_METADATA_TTL_SEC=86400
CMC_LISTINGS_REFRESH_SEC=21600
CMC_WS_MAX_SUBSCRIPTIONS=100
CMC_WS_LATEST_LIMIT=60
CMC_STREAM_CANDLE_INTERVALS=1min,5min,15min,1h,1d
CMC_RECONCILE_MAX_ASSETS=25
CMC_USAGE_REFRESH_SEC=900
CMC_SECURITY_CACHE_SEC=86400
CMC_FINDER_ASSET_LIMIT=50
CMC_REST_CONCURRENCY=4

# Authentication and owner access (required for hosted production).
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_SECRET_KEY=
HAVEN_OWNER_USER_IDS=

# Configurable commercial plans.
HAVEN_TRIAL_DAYS=7
HAVEN_TRIAL_BOTS=1
HAVEN_TRIAL_STRATEGIES=3
HAVEN_TRIAL_FINDERS=1
HAVEN_TRIAL_AI_DAILY=5
HAVEN_STARTER_PLAN_SLUG=haven_starter
HAVEN_STARTER_PRICE_MONTHLY=19
HAVEN_STARTER_PRICE_ANNUAL=190
HAVEN_STARTER_BOTS=3
HAVEN_STARTER_STRATEGIES=15
HAVEN_STARTER_FINDERS=3
HAVEN_STARTER_AI_DAILY=25
HAVEN_PRO_PLAN_SLUG=haven_pro
HAVEN_PRO_PRICE_MONTHLY=49
HAVEN_PRO_PRICE_ANNUAL=490
HAVEN_PRO_BOTS=10
HAVEN_PRO_STRATEGIES=50
HAVEN_PRO_FINDERS=10
HAVEN_PRO_AI_DAILY=100
HAVEN_ADVANCED_PLAN_SLUG=haven_advanced
HAVEN_ADVANCED_PRICE_MONTHLY=99
HAVEN_ADVANCED_PRICE_ANNUAL=990
HAVEN_ADVANCED_BOTS=30
HAVEN_ADVANCED_STRATEGIES=200
HAVEN_ADVANCED_FINDERS=30
HAVEN_ADVANCED_AI_DAILY=500

# Optional AI assistant; the daily per-plan limit is enforced server-side.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Operations, compliance and links.
HAVEN_LEGAL_ENTITY_NAME=
HAVEN_LEGAL_CONTACT_EMAIL=
HAVEN_TERMS_VERSION=
HAVEN_PRIVACY_VERSION=
HAVEN_DATA_LICENSE_CONFIRMED=0
HAVEN_SECRET_ROTATION_CONFIRMED=0
HAVEN_DEPLOYMENT_DASHBOARD_URL=
HAVEN_MONITORING_DASHBOARD_URL=
HAVEN_MONITORING_DSN=
HAVEN_BACKUP_DASHBOARD_URL=
HAVEN_CMC_DASHBOARD_URL=https://pro.coinmarketcap.com/account
HAVEN_CLERK_DASHBOARD_URL=https://dashboard.clerk.com
HAVEN_BACKUP_DIR=
HAVEN_BACKUP_ENCRYPTION_KEY=
HAVEN_REPOSITORY_URL=
HAVEN_ENGINE_RELEASE_PUBLIC_KEY=
