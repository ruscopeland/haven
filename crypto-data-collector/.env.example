# Copy to .env and fill in real values. Never commit .env.

ALCHEMY_API_KEY=
RPC_HTTP_BSC=
RPC_HTTP_ETHEREUM=
RPC_HTTP_BASE=

# Liquidity quality floor (USD)
HAVEN_MIN_TOKEN_LIQUIDITY_USD=100000

# GoPlus Security (https://gopluslabs.io) — liquid tokens only, daily budget
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=
# Local self-limit (token addresses scanned/day). Not GoPlus CU.
GOPLUS_DAILY_BUDGET=10000
GOPLUS_BATCH_SIZE=5
GOPLUS_MIN_INTERVAL_SEC=3
GOPLUS_REFRESH_DAYS=14
GOPLUS_TICK_MAX=40
GOPLUS_TICK_SEC=21600

# --- Alchemy free-tier defaults (owner 2026-07-10) ---
# BSC only at 60s polls keeps CU low. Re-enable multi-chain when you upgrade:
# ENABLE_CHAIN_ETHEREUM=1
# ENABLE_CHAIN_BASE=1
# POLL_SECONDS_BSC=15
# POLL_SECONDS_ETHEREUM=30
# POLL_SECONDS_BASE=30

# CMC market layer (coming): CMC_API_KEY=  for mcap/vol/candles/display
