# Haven market-data collector. ONE instance for the whole platform — market
# data is identical for every user, so this never scales per-customer.
# Railway build: root directory crypto-data-collector, Dockerfile.collector.
# Needs $DATABASE_URL (the same Postgres the API uses).
FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

CMD ["python", "standalone_collector.py"]
