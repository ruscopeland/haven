# Haven Engine configuration.
# Run setup.bat (or `npm run setup`) to generate `.env` interactively,
# or copy this file to `.env` and fill in the three values below.

# The API address for your Haven account (from the website / DEPLOY.md).
HAVEN_API_URL=https://api-production-0dc54.up.railway.app

# Your connection key: Haven website -> Settings -> "Connect your engine".
HAVEN_API_KEY=

# Your trading wallet's private key. STAYS ON THIS COMPUTER — never sent to
# Haven. Use a dedicated wallet holding only the funds you trade.
PRIVATE_KEY=

# --- Optional tuning (safe defaults if omitted) ---
# RPC_URL=https://bsc-dataseed.binance.org
# GAS_PRICE_GWEI=1
# SLIPPAGE_PCT=0.5
# Used only when a marker was placed without an amount:
# QUICK_BUY_PERCENT=5
# QUICK_SELL_PERCENT=100

# --- Local solo mode only (the owner's own machine) ---
# Point at a local API running with HAVEN_SOLO=1; no connection key needed.
# API_URL=http://localhost:8000
