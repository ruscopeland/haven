# Haven Engine configuration.
# Run setup.bat (or `npm run setup`) to generate `.env` interactively,
# or copy this file to `.env` and fill in the three values below.

# The API address for your Haven account (from the website / DEPLOY.md).
HAVEN_API_URL=https://api.haven.trading

# Run setup. On Windows, the connection key and wallet private key are stored
# outside this folder in a current-user DPAPI-encrypted credential blob.

# --- Optional tuning (safe defaults if omitted) ---
# RPC_URL=https://bsc-dataseed.binance.org
# GAS_PRICE_GWEI=1
# SLIPPAGE_PCT=0.5
# Required for live trading. Comma-separated router contract addresses that
# Haven may call; obtain the current address from the aggregator's official
# deployment documentation and verify it on the chain explorer.
# HAVEN_ALLOWED_ROUTER_ADDRESSES=0x...
# Optional comma-separated allowed function selectors (for extra lockdown).
# HAVEN_ALLOWED_SWAP_SELECTORS=0x...
# Used only when a marker was placed without an amount:
# QUICK_BUY_PERCENT=5
# QUICK_SELL_PERCENT=100

# --- Local solo mode only (the owner's own machine) ---
# Point at a local API running with HAVEN_SOLO=1; no connection key needed.
# API_URL=http://localhost:8000
