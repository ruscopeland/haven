# Haven web app configuration (Vite reads VITE_* at build time).
#
# LOCAL / SOLO DEV: leave the Clerk key blank. With no Clerk key the app skips
# login and talks to a local API running with HAVEN_SOLO=1 — the old behavior.
#
# CLOUD: set VITE_API_URL and VITE_CLERK_PUBLISHABLE_KEY (see DEPLOY.md).

# The Haven API base URL. Blank => http://localhost:8000.
# Production (Cloudflare Pages build): https://api-production-0dc54.up.railway.app
# Do NOT use https://api.haven.trade — that host is not Haven and causes "Failed to fetch".
VITE_API_URL=

# Clerk publishable key (starts pk_test_ or pk_live_). Blank => solo mode (no login).
VITE_CLERK_PUBLISHABLE_KEY=

# Clerk Billing: plan slug(s) that unlock live trading + engine (match Dashboard).
VITE_CLERK_PAID_PLANS=pro
# Feature key on those plans (optional; has({ feature }) also counts as paid).
VITE_CLERK_LIVE_FEATURE=live_trading

# LOCAL/SOLO ONLY: optional default public wallet ADDRESS while developing.
# Production builds must leave this blank — a real address here is shared with
# every new account (empty localStorage falls back to this baked-in value).
# The private key stays in the desktop engine only; this app never signs.
VITE_WALLET_ADDRESS=
