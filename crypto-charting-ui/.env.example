# Haven web app configuration (Vite reads VITE_* at build time).
#
# LOCAL / SOLO DEV: leave the Clerk key blank. With no Clerk key the app skips
# login and talks to a local API running with HAVEN_SOLO=1 — the old behavior.
#
# CLOUD: set VITE_API_URL and VITE_CLERK_PUBLISHABLE_KEY (see DEPLOY.md).

# The Haven API base URL. Blank => http://localhost:8000.
VITE_API_URL=

# Clerk publishable key (starts pk_test_ or pk_live_). Blank => solo mode (no login).
VITE_CLERK_PUBLISHABLE_KEY=

# Public wallet ADDRESS (not the key!) shown on the Dashboard wallet panel.
# The private key stays in the desktop engine only — this app never signs.
VITE_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
